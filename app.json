{
  "expo": {
    "name": "Billsy",
    "slug": "billsy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5B5FEF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arun.billsy",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "NSUserNotificationUsageDescription": "Billsy sends reminders before your subscriptions renew so you're never caught off guard."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#5B5FEF"
      },
      "package": "com.arun.billsy",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#5B5FEF",
          "sounds": [],
          "mode": "production"
        }
      ],
      "expo-asset",
      "expo-font"
    ]
  }
}
